{
  "name": "anatolia-sim",
  "version": "1.3.8",
  "private": true,
  "main": "desktop/main.mjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "cd client && npm install --include=dev && npm run build && cd ../server && npm install --include=dev",
    "desktop": "npm run build && electron desktop/main.mjs",
    "dist": "npm run build && electron-builder --win nsis",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "dist:linux": "npm run build && electron-builder --linux AppImage",
    "start": "cd server && npm start",
    "test": "cd server && npm test && cd ../client && npm test"
  },
  "devDependencies": {
    "electron": "^31.6.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.atabeylers.anatoliasim",
    "productName": "Anatolia Sim",
    "copyright": "Copyright © 2024 Atabeyler",
    "files": [
      "desktop/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "client/dist",
        "to": "client/dist"
      },
      {
        "from": "server/src",
        "to": "server/src"
      },
      {
        "from": "server/node_modules",
        "to": "server/node_modules"
      },
      {
        "from": "server/package.json",
        "to": "server/package.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Anatolia Sim",
      "deleteAppDataOnUninstall": false,
      "license": "LICENSE.txt",
      "language": "1033"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.education"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Education"
    },
    "directories": {
      "output": "release/installer",
      "buildResources": "desktop/build-assets"
    },
    "publish": {
      "provider": "github",
      "owner": "atabeyler",
      "repo": "anatolia-sim",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
